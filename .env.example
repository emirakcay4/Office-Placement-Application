# ──────────────────────────────────────────────
# OPA Backend — Environment Variables Template
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# DO NOT commit .env to version control!

SECRET_KEY=your-secret-key-here
DEBUG=True

# PostgreSQL
DB_NAME=opa_db
DB_USER=postgres
DB_PASSWORD=your-db-password-here
DB_HOST=localhost
DB_PORT=5432
